[Interface]
Address = {{ wireguard_address }}
PrivateKey = {{ wireguard_private_key }}
{% if wireguard_role | default('client') == 'server' %}
ListenPort = {{ wireguard_port }}
PostUp   = iptables -A FORWARD -i %i -j ACCEPT; iptables -A FORWARD -o %i -j ACCEPT; iptables -t nat -A POSTROUTING -o {{ wireguard_outbound_interface | default('eth0') }} -j MASQUERADE
PostDown = iptables -D FORWARD -i %i -j ACCEPT; iptables -D FORWARD -o %i -j ACCEPT; iptables -t nat -D POSTROUTING -o {{ wireguard_outbound_interface | default('eth0') }} -j MASQUERADE
{% elif wireguard_port is defined %}
ListenPort = {{ wireguard_port }}
{% endif %}

{% for peer in wireguard_peers | default([]) %}
[Peer]
{% if peer.name is defined %}
# {{ peer.name }}
{% endif %}
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.allowed_ips | join(', ') if peer.allowed_ips is iterable and peer.allowed_ips is not string else peer.allowed_ips }}
{% if peer.endpoint is defined %}
Endpoint = {{ peer.endpoint }}
{% endif %}
{% if peer.persistent_keepalive is defined %}
PersistentKeepalive = {{ peer.persistent_keepalive }}
{% endif %}

{% endfor %}